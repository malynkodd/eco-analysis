# ============================================================================
# eco-analysis — environment configuration template
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================================

# ─── Runtime mode ────────────────────────────────────────────────────────────
# Allowed: development | production
# In production, /docs and /redoc are disabled.
ENVIRONMENT=development

# Number of gunicorn workers per service (fixed; ignores host CPU detection
# because cgroups don't always expose accurate CPU counts).
WORKERS=4

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=ecouser
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ecodb
DATABASE_URL=postgresql://ecouser:change_me_in_production@postgres:5432/ecodb

# ─── JWT (RS256) ─────────────────────────────────────────────────────────────
# Paths inside the container — keys are mounted via docker-compose.
# Generate with: ./scripts/generate_keys.sh
JWT_PRIVATE_KEY_PATH=/run/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/keys/jwt_public.pem

# Token claims
JWT_ISSUER=eco-analysis-auth
JWT_AUDIENCE=eco-analysis-api
JWT_EXPIRE_MINUTES=60

# ─── Admin bootstrap ─────────────────────────────────────────────────────────
# Required ONLY on the first boot when no admin exists in the DB.
# After that, omit them — the service will not auto-recreate the admin.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password
ADMIN_EMAIL=admin@eco-analysis.local

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use the gateway URL.
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,https://localhost

# ─── TLS (NGINX) ─────────────────────────────────────────────────────────────
# Self-signed certs for dev: generate with scripts/generate_tls.sh
TLS_CERT_PATH=/etc/nginx/ssl/cert.pem
TLS_KEY_PATH=/etc/nginx/ssl/key.pem
